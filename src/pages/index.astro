---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const INITIAL_COUNT = 8;

const allPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const initialPosts = allPosts.slice(0, INITIAL_COUNT);
const totalCount = allPosts.length;
const hasMore = totalCount > INITIAL_COUNT;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<section class="hero">
			<div class="container hero-inner">
				<h1>{SITE_TITLE}</h1>
				<p class="hero-kicker">{SITE_DESCRIPTION}</p>
				<p class="hero-kicker" style="max-width: 62ch;">
					Um canto pra juntar lembranças e reflexões, sem barulho. Texto bom é texto que respira.
				</p>
				<div class="hero-actions">
					<a class="cta" href="/blog">Ler os textos</a>
					<a class="cta cta-outline" href="/pdfs/livro-completo.pdf" download>Baixar livro (PDF)</a>
				</div>
			</div>
		</section>

		<main>
			<section class="section">
				<div class="container">
					<div class="section-title">
						<h2 style="margin:0;">Últimas prosas</h2>
						<a href="/blog">Ver todas ({totalCount})</a>
					</div>

					<div class="grid post-grid-home" id="post-grid">
						{initialPosts.map((post) => (
							<a class="card post-card-home" href={`/blog/${post.id}/`}>
								<div class="post-thumb-home">
									{post.data.heroImage ? (
										<Image
											src={post.data.heroImage}
											alt={post.data.heroImageAlt || `Capa do post ${post.data.title}`}
											widths={[400, 800, 1200]}
											sizes="(max-width: 620px) 100vw, (max-width: 980px) 50vw, 25vw"
											loading="lazy"
										/>
									) : (
										<div class="post-thumb-fallback-home" aria-hidden="true" />
									)}
								</div>
								<div class="post-card-body-home">
									<div class="tag-row">
										{post.data.tags?.slice(0, 1).map((t) => (
											<span class="tag">{t}</span>
										))}
										{post.data.placeLabel && <span class="tag">{post.data.placeLabel}</span>}
									</div>
									<h3 class="card-title">{post.data.title}</h3>
									<p class="card-desc">{post.data.description}</p>
									<p class="meta" style="margin:0;">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						))}
					</div>

					{hasMore && (
						<div class="ver-mais-wrap" id="ver-mais-wrap">
							<button id="ver-mais-btn" class="cta-ver-mais" data-loaded={INITIAL_COUNT} data-total={totalCount}>
								Ver mais prosas (<span id="restantes">{totalCount - INITIAL_COUNT}</span> restantes)
							</button>
						</div>
					)}
				</div>
			</section>
		</main>

		<Footer />

		<style>
			.hero-actions {
				display: flex;
				gap: var(--space-md);
				flex-wrap: wrap;
			}

			.cta-outline {
				background: transparent;
				color: var(--accent-primary);
				border: 1px solid var(--accent-primary);
			}

			.cta-outline:hover {
				background: var(--accent-primary);
				color: white;
			}

			.post-grid-home {
				grid-template-columns: repeat(4, 1fr);
			}

			.post-card-home {
				padding: 0;
				overflow: hidden;
				min-height: 0;
				transition: transform 180ms ease, box-shadow 180ms ease;
			}

			.post-card-home:hover {
				transform: translateY(-2px);
			}

			.post-thumb-home {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: var(--tag-bg);
				border-bottom: 1px solid var(--border-light);
			}

			.post-thumb-home :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 260ms ease;
			}

			.post-card-home:hover .post-thumb-home :global(img) {
				transform: scale(1.03);
			}

			.post-thumb-fallback-home {
				width: 100%;
				height: 100%;
				background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));
			}

			.post-card-body-home {
				padding: var(--space-md);
				display: flex;
				flex-direction: column;
				gap: var(--space-sm);
			}

			.ver-mais-wrap {
				display: flex;
				justify-content: center;
				margin-top: var(--space-xl);
			}

			.cta-ver-mais {
				background: transparent;
				color: var(--accent-primary);
				border: 2px solid var(--accent-primary);
				font-size: 1rem;
				padding: 0.75rem 2rem;
				cursor: pointer;
				border-radius: 4px;
				font-family: inherit;
				transition: background 180ms ease, color 180ms ease;
			}

			.cta-ver-mais:hover {
				background: var(--accent-primary);
				color: white;
			}

			.cta-ver-mais:disabled {
				opacity: 0.5;
				cursor: default;
			}

			@media (max-width: 980px) {
				.post-grid-home {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 620px) {
				.post-grid-home {
					grid-template-columns: 1fr;
				}
			}
		</style>

		<script>
		const BATCH = 8;

		const btn = document.getElementById('ver-mais-btn') as HTMLButtonElement | null;
		const wrap = document.getElementById('ver-mais-wrap');
		const grid = document.getElementById('post-grid');

		if (btn && wrap && grid) {
			let allPosts: any[] | null = null;
			let loaded = parseInt(btn.dataset.loaded || '8');
			const total = parseInt(btn.dataset.total || '0');

			function formatDate(iso: string) {
				const d = new Date(iso);
				return d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
			}

			function renderCard(p: any) {
				const card = document.createElement('a');
				card.className = 'card post-card-home';
				card.href = `/blog/${p.id}/`;
				card.innerHTML = `
					<div class="post-thumb-home">
						${p.heroImage
							? `<img src="${p.heroImage}" alt="Capa de ${p.title}" loading="lazy" style="width:100%;height:100%;object-fit:cover;">`
							: `<div class="post-thumb-fallback-home" aria-hidden="true"></div>`
						}
					</div>
					<div class="post-card-body-home">
						<div class="tag-row">
							${p.tags?.slice(0, 1).map((t: string) => `<span class="tag">${t}</span>`).join('') ?? ''}
							${p.placeLabel ? `<span class="tag">${p.placeLabel}</span>` : ''}
						</div>
						<h3 class="card-title">${p.title}</h3>
						<p class="card-desc">${p.description}</p>
						<p class="meta" style="margin:0;">${formatDate(p.pubDate)}</p>
					</div>`;
				return card;
			}

			btn.addEventListener('click', async () => {
				btn.disabled = true;
				btn.textContent = 'Carregando…';

				if (!allPosts) {
					const res = await fetch('/blog-index.json');
					allPosts = await res.json();
				}

				const batch = allPosts!.slice(loaded, loaded + BATCH);
				batch.forEach((p) => grid.appendChild(renderCard(p)));
				loaded += batch.length;

				const remaining = total - loaded;
				if (remaining <= 0) {
					wrap.style.display = 'none';
				} else {
					btn.disabled = false;
					btn.innerHTML = `Ver mais prosas (<span id="restantes">${remaining}</span> restantes)`;
				}
			});
		}
		</script>
	</body>
</html>
