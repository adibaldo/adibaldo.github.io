s. Format as markdown checklist. Write the result to HEARTBEAT.md under the '## 🔔 PRs Pending Review' section (replace that section only). If no PRs, write 'No open PRs.' under the section.\\\"\\n      },\\n      \\\"delivery\\\": {\\n        \\\"mode\\\": \\\"none\\\"\\n      },\\n      \\\"state\\\": {\\n        \\\"nextRunAtMs\\\": 1771313335379,\\n        \\\"lastRunAtMs\\\": 1771309735330,\\n        \\\"lastStatus\\\": \\\"error\\\",\\n        \\\"lastDurationMs\\\": 49,\\n        \\\"consecutiveErrors\\\": 38,\\n        \\\"lastError\\\": \\\"Error: All models failed (1): google/gemini-3-flash-preview: Provider google is in cooldown (all profiles unavailable) (rate_limit)\\\"\\n      }\\n    },\\n    {\\n      \\\"id\\\": \\\"3cab287d-3eb9-4946-84c4-5b45edcc1a06\\\",\\n      \\\"agentId\\\": \\\"aparicio\\\",\\n      \\\"name\\\": \\\"memory-sync\\\",\\n      \\\"enabled\\\": true,\\n      \\\"createdAtMs\\\": 1771096039127,\\n      \\\"updatedAtMs\\\": 1771309739967,\\n      \\\"schedule\\\": {\\n        \\\"kind\\\": \\\"every\\\",\\n        \\\"everyMs\\\": 21600000,\\n        \\\"anchorMs\\\": 1771096179772\\n      },\\n      \\\"sessionTarget\\\": \\\"isolated\\\",\\n      \\\"wakeMode\\\": \\\"now\\\",\\n      \\\"payload\\\": {\\n        \\\"message\\\": \\\"Execute git sync: git add . && git commit -m 'chore: auto-sync memory' && git push. Ignore 'nothing to commit' errors.\\\",\\n        \\\"kind\\\": \\\"agentTurn\\\"\\n      },\\n      \\\"delivery\\\": {\\n        \\\"mode\\\": \\\"announce\\\"\\n      },\\n      \\\"state\\\": {\\n        \\\"nextRunAtMs\\\": 1771313339967,\\n        \\\"lastRunAtMs\\\": 1771309739847,\\n        \\\"lastStatus\\\": \\\"error\\\",\\n        \\\"lastDurationMs\\\": 120,\\n        \\\"consecutiveErrors\\\": 6,\\n        \\\"lastError\\\": \\\"Error: All models failed (1): google/gemini-3-flash-preview: Provider google is in cooldown (all profiles unavailable) (rate_limit)\\\"\\n      }\\n    },\\n    {\\n      \\\"id